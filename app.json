{
  "expo": {
    "name": "MyLift",
    "slug": "mylift-v2",
    "scheme": "mylift",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050509",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "imageWidth": 220,
      "backgroundColor": "#050509"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maxime.mylift",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories",
          "instagram",
          "instagram-stories"
        ],
        "NSCameraUsageDescription": "MyLift utilise l'appareil photo pour ajouter une photo à tes posts et à ton profil.",
        "NSPhotoLibraryUsageDescription": "MyLift accède à ta galerie pour choisir une photo de post ou de profil.",
        "NSPhotoLibraryAddUsageDescription": "MyLift enregistre dans ta galerie les images générées pour le partage.",
        "NSHealthShareUsageDescription": "MyLift lit ton poids depuis Apple Santé pour synchroniser tes pesées.",
        "NSHealthUpdateUsageDescription": "MyLift écrit tes pesées dans Apple Santé pour les retrouver partout.",
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      "expo-live-activity",
      "@kingstinct/react-native-healthkit"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ffd6bf8-e0ac-4b5d-b2f8-3435942a37b2"
      }
    },
    "owner": "maxlocar"
  }
}
